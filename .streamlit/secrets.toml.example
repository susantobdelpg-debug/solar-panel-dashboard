# Example configuration file for Streamlit secrets.
# Rename this file to 'secrets.toml' in the '.streamlit' directory for local development.
# On Streamlit Community Cloud, paste these keys directly into the app settings secrets panel.

# Example: API keys for external services (if needed in the future)
# GOOGLE_MAPS_API_KEY = "YOUR_GOOGLE_MAPS_API_KEY_HERE"
# OPENWEATHER_API_KEY = "YOUR_OPENWEATHER_API_KEY_HERE"
